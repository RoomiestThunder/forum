# Server Configuration
PORT=8080
READ_TIMEOUT_SECS=15
WRITE_TIMEOUT_SECS=15
IDLE_TIMEOUT_SECS=60

# Database Configuration
DB_PATH=forum.db
DB_MAX_OPEN_CONN=25
DB_MAX_IDLE_CONN=5
DB_CONN_MAX_LIFE_MINS=5

# Session Configuration
SESSION_DURATION_HOURS=24
COOKIE_NAME=session
COOKIE_PATH=/
COOKIE_SAMESITE=Lax
COOKIE_HTTPONLY=true
COOKIE_SECURE=false

# UI Configuration
PAGINATION_SIZE=5
POST_TITLE_MAX_LEN=20
COMMENT_MAX_LEN=500

# Environment
# Set to 'production' or 'development'
ENVIRONMENT=development
