# ── Server ──────────────────────────────────────────
PORT=8080
READ_TIMEOUT_SECS=15
WRITE_TIMEOUT_SECS=15
IDLE_TIMEOUT_SECS=60

# ── Database ─────────────────────────────────────────
# Use DATABASE_URL for PostgreSQL (takes priority over DB_PATH)
# DATABASE_URL=postgres://forum:forum@localhost:5432/forum?sslmode=disable
DB_PATH=forum.db
DB_MAX_OPEN_CONN=25
DB_MAX_IDLE_CONN=5
DB_CONN_MAX_LIFE_MINS=5

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_DURATION_MIN=15
JWT_REFRESH_DURATION_DAYS=7

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MinIO / S3 ───────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=forum
MINIO_USE_SSL=false

# ── Session (HTML frontend) ───────────────────────────
SESSION_DURATION_HOURS=24
COOKIE_NAME=session
COOKIE_PATH=/
COOKIE_SAMESITE=Lax
COOKIE_HTTPONLY=true
COOKIE_SECURE=false

# ── UI ───────────────────────────────────────────────
PAGINATION_SIZE=5
POST_TITLE_MAX_LEN=20
COMMENT_MAX_LEN=500
